# ─── Bët — Variables d'environnement PROD ───────────────────────────────────
# Copier en `.env` à la racine. ⚠ Ne jamais commiter de secret réel.
#
# Différences notables vs .env.dev.example :
#   - APP_DEBUG=false, APP_ENV=production
#   - URLs relatives pour le frontend (passe par nginx-edge)
#   - Mots de passe / clés à FORCER (pas de défauts)

# ── App
# ⚠ APP_KEY, JWT_SECRET, QR_TOKEN_SECRET sont volontairement OMIS de ce fichier.
# Les exposer ici les passerait au container comme env vars vides via env_file,
# ce qui empêcherait Laravel de lire celles auto-générées dans /var/www/.env.
APP_NAME=Bet
APP_ENV=production
APP_DEBUG=false
# APP_URL : à remplacer par https://app.bet.sn en vrai prod
APP_URL=http://localhost
FRONTEND_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database — REMPLACER par des secrets forts
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bet_db
DB_USERNAME=bet_app
DB_PASSWORD=change_me_strong_password

# ── Sessions / Cache / Queue
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── JWT — JWT_SECRET auto-généré au 1er boot (omis volontairement, voir warning APP_KEY)
JWT_TTL=15
JWT_REFRESH_TTL=10080

# ── QR token — QR_TOKEN_SECRET auto-généré au 1er boot (omis, voir warning APP_KEY)

# ── Anti-spam alertes
ANTISPAM_DISTANCE_METERS=100
ANTISPAM_TIME_WINDOW_SECONDS=120

# ── MinIO / S3 — REMPLACER les credentials
AWS_ACCESS_KEY_ID=change_me_minio_user
AWS_SECRET_ACCESS_KEY=change_me_minio_password_min_8_chars
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=bet-media
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_ROOT_USER=change_me_minio_user
MINIO_ROOT_PASSWORD=change_me_minio_password_min_8_chars
# MINIO_CORS_ORIGIN : à remplacer par https://app.bet.sn en vrai prod
MINIO_CORS_ORIGIN=http://localhost

# ── Reverb WebSocket — REMPLACER les secrets
REVERB_APP_ID=bet-app
REVERB_APP_KEY=change_me_reverb_key
REVERB_APP_SECRET=change_me_reverb_secret_long_random
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# ── SMS provider
SMS_PROVIDER=log
SMS_FROM=BET

# ── Port hôte unique en prod : nginx-edge sert toute la stack sur :80.
# Postgres, Redis, MinIO, backend-php, backend-reverb sont en réseau interne
# uniquement (`expose:` au lieu de `ports:`). Pour la console MinIO ops voir
# le header de docker-compose.prod.yml (tunnel SSH ou docker exec).
HTTP_PORT=80

# ── Frontend (NEXT_PUBLIC_* — INLINÉS AU BUILD)
# Tout en relatif : passe par nginx-edge sur le même host que la page
NEXT_PUBLIC_API_URL=/api/v1
# NEXT_PUBLIC_MAPBOX_TOKEN : à renseigner AVANT `make build-prod` (inliné dans le bundle)
NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_REVERB_HOST vide → pusher-js prend window.location.hostname
NEXT_PUBLIC_REVERB_HOST=
NEXT_PUBLIC_REVERB_PORT=80
# NEXT_PUBLIC_REVERB_SCHEME : passer en `wss` derrière TLS
NEXT_PUBLIC_REVERB_SCHEME=ws
NEXT_PUBLIC_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_DEFAULT_LAT=14.6928
NEXT_PUBLIC_DEFAULT_LNG=-17.4467
