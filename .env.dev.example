# ─── Bët — Variables d'environnement DEV ────────────────────────────────────
# Copier en `.env` à la racine. Lu par docker-compose.dev.yml ET par le backend
# (mounté à /var/www/.env).

# ── App
# ⚠ APP_KEY, JWT_SECRET, QR_TOKEN_SECRET sont volontairement OMIS de ce fichier.
# Les exposer ici les passerait au container comme env vars vides via env_file,
# ce qui empêcherait Laravel de lire celles auto-générées dans /var/www/.env.
APP_NAME=Bet
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (postgres dans compose)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bet_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Sessions / Cache / Queue
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── JWT — JWT_SECRET auto-généré au 1er boot (omis volontairement, voir warning APP_KEY)
JWT_TTL=15
JWT_REFRESH_TTL=10080

# ── QR token — QR_TOKEN_SECRET auto-généré au 1er boot (omis, voir warning APP_KEY)

# ── Anti-spam alertes
ANTISPAM_DISTANCE_METERS=100
ANTISPAM_TIME_WINDOW_SECONDS=120

# ── MinIO / S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=bet-media
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CORS_ORIGIN=http://localhost:3000

# ── Reverb WebSocket
REVERB_APP_ID=bet-app
REVERB_APP_KEY=bet-key
REVERB_APP_SECRET=bet-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── SMS (à configurer selon le provider)
SMS_PROVIDER=log
SMS_FROM=BET

# ── Ports hôte (override si conflits locaux)
BACKEND_PORT=8000
FRONTEND_PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# ML_API_PORT : port hôte high-range improbable (5000 = AirPlay macOS Monterey+,
# 5050 = parfois pris par d'autres outils). Override si conflit local.
ML_API_PORT=47821

# ── ML Microservice (FastAPI)
# Clés vides → fallback PKL pour /classifier, IA complète indisponible
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
DEEPSEEK_API_KEY=
WEB_CONCURRENCY=2

# ── Frontend (NEXT_PUBLIC_* — inlinés au build, non secrets)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_SCHEME=ws
NEXT_PUBLIC_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_DEFAULT_LAT=14.6928
NEXT_PUBLIC_DEFAULT_LNG=-17.4467
