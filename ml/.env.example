# ─── Bët ML — variables d'environnement ────────────────────────────────────
# Copier en `ml/.env`. Les deux clés ont une formule gratuite.

# Groq Cloud — https://console.groq.com  (free tier généreux)
# Utilisé par /v1/classify et /v1/vision/analyze
GROQ_API_KEY=

# Modèles Groq (overrides optionnels)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Deepgram — https://console.deepgram.com  (200 $ de crédit gratuit)
# Utilisé par /v1/transcribe
DEEPGRAM_API_KEY=

# Modèle d'embeddings multilingue (téléchargé automatiquement par
# sentence-transformers au premier appel)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Préchauffer le modèle d'embeddings au démarrage (évite la latence du 1er appel)
WARM_EMBEDDINGS=false

# Service
PORT=5000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
